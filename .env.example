# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# required when using NVIDIA-hosted models directly
NVIDIA_API_KEY=****

# optional NVIDIA image generation/editing configuration
NVIDIA_IMAGE_MODEL=black-forest-labs/flux.1-dev
NVIDIA_IMAGE_API_URL=
NVIDIA_IMAGE_EDIT_API_URL=
NVIDIA_IMAGE_WIDTH=1024
NVIDIA_IMAGE_HEIGHT=1024
NVIDIA_SAFETY_MODEL=nvidia/llama-3.1-nemotron-safety-8b-v1

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****
DATABASE_URL=****

# required for document embeddings/RAG
VOYAGE_API_KEY=****

# optional base URL for custom API tools
API_BASE_URL=

# https://vercel.com/docs/redis
REDIS_URL=****
